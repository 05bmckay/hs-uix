{
  "name": "@hs-uix/form",
  "version": "0.7.0",
  "description": "Declarative, config-driven FormBuilder for HubSpot UI Extensions",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "index.d.ts",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "echo 'Publish via root hs-uix package instead' && exit 1"
  },
  "peerDependencies": {
    "@hubspot/ui-extensions": ">=0.12.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@hubspot/ui-extensions": "latest",
    "react": "^18.0.0",
    "tsup": "^8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/05bmckay/hs-uix.git",
    "directory": "packages/form"
  },
  "homepage": "https://github.com/05bmckay/hs-uix/tree/main/packages/form#readme",
  "keywords": [
    "hubspot",
    "ui-extensions",
    "form",
    "formbuilder",
    "crm",
    "hs-uix"
  ]
}
